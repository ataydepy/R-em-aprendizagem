# carregando pacotes necessários
library(tidyverse)
# importando os dados 
url <- "https://archive.ics.uci.edu/ml/machine-learning-databases/00519/heart_failure_clinical_records_dataset.csv"

df <- read_csv(url)
glimpse(df)

# tranformando variaveis
df <- df %>% 
  mutate(
    anaemia = factor(anaemia, levels =c(0,1),
                     labels = c("Não", "Sim")),
    high_blood_pressure = factor(high_blood_pressure, levels =c(0,1),
                     labels = c("Não", "Sim")),
    diabetes = factor(diabetes, levels =c(0,1),
                     labels = c("Não", "Sim")),
    sex = factor(sex, levels =c(0,1),
                     labels = c("Mulher", "Homem")),
    smoking = factor(smoking, levels =c(0,1),
                     labels = c("Não", "Sim")),
    DEATH_EVENT = factor(DEATH_EVENT, levels =c(0,1),
                     labels = c("Vivo", "Morto"))
  )

# grafico de barras

df %>% 
  ggplot(aes(y = high_blood_pressure,
             fill = DEATH_EVENT)) + 
  geom_bar(position = "fill") +
  theme_minimal() + 
  scale_fill_manual(values = c("Vivo" = "grey80", "Morto" = "red4")) +
  labs(
    title = "Impacto da Hipertensão em Pacientes Cardíacos",
    subtitle = "Pacientes com hipertensão têm maiores taxas de óbito",
    x = "Hipertensão",
    y = "",
    fill = "Desfecho" 
  )
#  tabelas
library(gt)

tab_aux <- df %>% 
  group_by(high_blood_pressure) %>% 
  summarise(taxa_obito = n()),
tab_aux
